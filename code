<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YARA Rule Builder</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { background:#080d14; color:#e0e0e0; font-family:Courier New,monospace; min-height:100vh; }
input, select, textarea { background:#0d1117; border:1px solid #2a2a3a; border-radius:4px; color:#e0e0e0; font-family:Courier New,monospace; font-size:0.82rem; padding:8px 10px; width:100%; outline:none; }
select { width:auto; }
label { color:#4fc3f7; font-size:0.72rem; letter-spacing:0.12em; margin-bottom:4px; display:block; }
.header { background:#0d1117; border-bottom:1px solid #00ff41; padding:16px 24px; display:flex; align-items:center; gap:8px; }
.dot { width:10px; height:10px; border-radius:50%; display:inline-block; }
.tabs { display:flex; border-bottom:1px solid #1a1a2e; background:#0a0f1a; }
.tab { padding:12px 24px; background:transparent; border:none; border-bottom:2px solid transparent; color:#555; font-family:Courier New,monospace; font-size:0.82rem; cursor:pointer; letter-spacing:0.08em; text-transform:uppercase; }
.tab.active { border-bottom:2px solid #00ff41; color:#00ff41; }
.content { max-width:900px; margin:0 auto; padding:24px 16px; }
.screen { display:none; }
.screen.active { display:block; }
.card { background:#0d1117; border:1px solid #1a1a2e; border-radius:8px; padding:20px; margin-bottom:20px; }
.card-title { color:#00ff41; font-size:0.7rem; letter-spacing:0.2em; margin-bottom:14px; }
.grid2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.grid4 { display:grid; grid-template-columns:1fr 1fr 2fr 1fr; gap:10px; }
.string-item { background:#080d14; border:1px solid #1a1a2e; border-radius:6px; padding:14px; margin-bottom:10px; }
.string-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.btn { background:transparent; font-family:Courier New,monospace; font-size:0.82rem; padding:12px 32px; border-radius:4px; cursor:pointer; letter-spacing:0.1em; }
.btn-green { border:1px solid #00ff41; color:#00ff41; }
.btn-green:hover { background:#00ff41; color:#0a0a0a; }
.btn-blue { border:1px solid #4fc3f7; color:#4fc3f7; }
.btn-small { font-size:0.72rem; padding:4px 12px; }
.btn-remove { background:transparent; border:none; color:#ff4444; cursor:pointer; font-family:Courier New,monospace; font-size:0.75rem; }
.condition-shortcuts { margin-top:10px; display:flex; gap:8px; flex-wrap:wrap; }
.shortcut { background:#0a0f1a; border:1px solid #2a2a3a; color:#888; font-family:Courier New,monospace; font-size:0.7rem; padding:4px 10px; border-radius:4px; cursor:pointer; }
.validation { border-radius:8px; padding:16px; margin-top:16px; }
.valid { background:#001a00; border:1px solid #00ff41; color:#00ff41; }
.invalid { background:#1a0000; border:1px solid #ff4444; }
.error-line { color:#ff4444; }
.preview-header { background:#161b22; padding:10px 16px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #00ff41; }
.preview-actions { display:flex; gap:8px; }
pre { padding:20px; font-size:0.82rem; line-height:1.8; color:#00ff41; overflow-x:auto; white-space:pre-wrap; }
.example-card { background:#0d1117; border:1px solid #1a1a2e; border-radius:8px; padding:20px; margin-bottom:16px; }
.example-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; }
.example-name { color:#febc2e; font-weight:bold; }
.severity { font-size:0.7rem; padding:3px 8px; border-radius:3px; font-weight:900; color:black; }
.sev-critical { background:#ff4444; }
.sev-high { background:#ff8800; }
.sev-medium { background:#febc2e; }
.sev-low { background:#00ff41; }
.example-desc { color:#888; font-size:0.8rem; margin-bottom:12px; }
.example-pre { background:#080d14; border-radius:6px; padding:12px; font-size:0.75rem; color:#00ff41; overflow-x:auto; margin-bottom:12px; white-space:pre; }
.hint { color:#888; font-size:0.8rem; margin-bottom:16px; }
@media(max-width:600px) { .grid2 { grid-template-columns:1fr; } .grid4 { grid-template-columns:1fr 1fr; } }
</style>
</head>
<body>

<div class="header">
  <span class="dot" style="background:#ff5f57;"></span>
  <span class="dot" style="background:#febc2e;"></span>
  <span class="dot" style="background:#28c840;"></span>
  <span style="color:#00ff41;font-weight:bold;font-size:1rem;margin-left:8px;">YARA Rule Builder</span>
  <span style="color:#444;font-size:0.75rem;margin-left:8px;">v1.0 - Threat Collections Toolkit</span>
</div>

<div class="tabs">
  <button class="tab active" onclick="switchTab('builder', this)">Builder</button>
  <button class="tab" onclick="switchTab('preview', this)">Preview</button>
  <button class="tab" onclick="switchTab('examples', this)">Examples</button>
</div>

<div class="content">
  <div class="screen active" id="tab-builder">
    <div class="card">
      <div class="card-title">RULE IDENTIFIER</div>
      <label>RULE NAME *</label>
      <input id="ruleName" placeholder="e.g. SuspiciousQRScanner" oninput="updatePreview()">
    </div>
    <div class="card">
      <div class="card-title">META</div>
      <div class="grid2">
        <div><label>DESCRIPTION *</label><input id="metaDesc" placeholder="What does this rule detect?" oninput="updatePreview()"></div>
        <div><label>AUTHOR *</label><input id="metaAuthor" placeholder="Your name" oninput="updatePreview()"></div>
        <div><label>SEVERITY</label><select id="metaSeverity" onchange="updatePreview()"><option>LOW</option><option>MEDIUM</option><option selected>HIGH</option><option>CRITICAL</option></select></div>
        <div><label>DATE</label><input id="metaDate" type="date" oninput="updatePreview()"></div>
      </div>
    </div>
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
        <div class="card-title" style="margin-bottom:0;">STRINGS</div>
        <button class="btn btn-green btn-small" onclick="addString()">+ ADD STRING</button>
      </div>
      <div id="strings-container"></div>
    </div>
    <div class="card">
      <div class="card-title">CONDITION</div>
      <label>CONDITION EXPRESSION *</label>
      <input id="condition" placeholder="e.g. any of them" value="any of them" oninput="updatePreview()">
      <div class="condition-shortcuts">
        <button class="shortcut" onclick="setCondition('any of them')">any of them</button>
        <button class="shortcut" onclick="setCondition('all of them')">all of them</button>
        <button class="shortcut" onclick="setCondition('$str1 and $str2')">$str1 and $str2</button>
        <button class="shortcut" onclick="setCondition('2 of them')">2 of them</button>
      </div>
    </div>
    <button class="btn btn-green" onclick="validateRule()">[ VALIDATE RULE ]</button>
    <div id="validation-result"></div>
  </div>

  <div class="screen" id="tab-preview">
    <div style="background:#0d1117;border:1px solid #00ff41;border-radius:8px;overflow:hidden;">
      <div class="preview-header">
        <span style="color:#888;font-size:0.75rem;" id="preview-filename">untitled.yar</span>
        <div class="preview-actions">
          <button class="btn btn-blue btn-small" onclick="copyRule()">COPY</button>
          <button class="btn btn-green btn-small" onclick="downloadRule()">DOWNLOAD .YAR</button>
        </div>
      </div>
      <pre id="preview-content"></pre>
    </div>
  </div>

  <div class="screen" id="tab-examples">
    <div class="hint">Click any example to load it into the builder.</div>
    <div id="examples-container"></div>
  </div>
</div>

<script>
var stringCount = 0;
var strings = [];
var EXAMPLES = [
  { name:"Suspicious_PowerShell", desc:"Detects obfuscated PowerShell execution", author:"Amanda", severity:"HIGH", strings:[{name:"ps1",type:"text",value:"powershell -enc",mod:"nocase"},{name:"ps2",type:"text",value:"-ExecutionPolicy Bypass",mod:"nocase"},{name:"ps3",type:"hex",value:"4D 5A 90 00",mod:""}], condition:"any of them" },
  { name:"Phishing_Doc_Macro", desc:"Detects Office documents with suspicious macros", author:"Amanda", severity:"MEDIUM", strings:[{name:"macro1",type:"text",value:"AutoOpen",mod:"nocase"},{name:"macro2",type:"text",value:"Shell(",mod:"nocase"},{name:"macro3",type:"text",value:"WScript.Shell",mod:"nocase"}], condition:"$macro1 and ($macro2 or $macro3)" },
  { name:"Ransomware_Indicator", desc:"Detects common ransomware strings", author:"Amanda", severity:"CRITICAL", strings:[{name:"note1",type:"text",value:"YOUR FILES HAVE BEEN ENCRYPTED",mod:"nocase"},{name:"note2",type:"text",value:"bitcoin",mod:"nocase"},{name:"ext1",type:"text",value:".locked",mod:""}], condition:"$note1 and $note2" },
  { name:"Qushing_Detection", desc:"Detects QR code phishing indicators in documents and emails", author:"Amanda", severity:"HIGH", strings:[{name:"str1",type:"text",value:"1inkedin.com",mod:"nocase"},{name:"str2",type:"text",value:"bit.ly",mod:"nocase"},{name:"str3",type:"text",value:"qr-login",mod:"nocase"},{name:"str4",type:"text",value:"scan to verify",mod:"nocase"}], condition:"any of them" }
];

function switchTab(name, el) {
  document.querySelectorAll('.screen').forEach(function(s) { s.classList.remove('active'); });
  document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
  document.getElementById('tab-' + name).classList.add('active');
  el.classList.add('active');
  if (name === 'preview') updatePreview();
}

function addString(preset) {
  stringCount++;
  var id = 'str_' + Date.now();
  var name = preset ? preset.name : 'str' + stringCount;
  var type = preset ? preset.type : 'text';
  var value = preset ? preset.value : '';
  var mod = preset ? preset.mod : 'nocase';
  strings.push({ id: id });
  var div = document.createElement('div');
  div.className = 'string-item';
  div.id = id;
  div.innerHTML =
    '<div class="string-header"><span style="color:#febc2e;font-size:0.75rem;">STRING #' + stringCount + '</span>' +
    '<button class="btn-remove" onclick="removeString(\'' + id + '\')">REMOVE</button></div>' +
    '<div class="grid4">' +
    '<div><label>IDENTIFIER</label><input placeholder="str1" value="' + name + '" oninput="updatePreview()"></div>' +
    '<div><label>TYPE</label><select onchange="updatePreview()"><option' + (type==='text'?' selected':'') + '>text</option><option' + (type==='hex'?' selected':'') + '>hex</option><option' + (type==='regex'?' selected':'') + '>regex</option></select></div>' +
    '<div><label>VALUE</label><input placeholder="string to match" value="' + value + '" oninput="updatePreview()"></div>' +
    '<div><label>MODIFIER</label><select onchange="updatePreview()"><option value="">none</option><option' + (mod==='nocase'?' selected':'') + '>nocase</option><option' + (mod==='wide'?' selected':'') + '>wide</option><option' + (mod==='ascii'?' selected':'') + '>ascii</option><option' + (mod==='nocase wide'?' selected':'') + '>nocase wide</option><option' + (mod==='nocase ascii'?' selected':'') + '>nocase ascii</option></select></div>' +
    '</div>';
  document.getElementById('strings-container').appendChild(div);
  updatePreview();
}

function removeString(id) {
  var el = document.getElementById(id);
  if (el) el.remove();
  strings = strings.filter(function(s) { return s.id !== id; });
  updatePreview();
}

function setCondition(val) {
  document.getElementById('condition').value = val;
  updatePreview();
}

function getStrings() {
  var items = document.querySelectorAll('.string-item');
  var result = [];
  for (var i = 0; i < items.length; i++) {
    var inputs = items[i].querySelectorAll('input');
    var selects = items[i].querySelectorAll('select');
    result.push({ name: inputs[0].value, type: selects[0].value, value: inputs[1].value, mod: selects[1].value });
  }
  return result;
}

function buildRule() {
  var name = document.getElementById('ruleName').value || 'untitled';
  var desc = document.getElementById('metaDesc').value;
  var author = document.getElementById('metaAuthor').value;
  var severity = document.getElementById('metaSeverity').value;
  var date = document.getElementById('metaDate').value;
  var condition = document.getElementById('condition').value;
  var strs = getStrings();
  var lines = [];
  lines.push('rule ' + name + ' {');
  lines.push('  meta:');
  lines.push('    description = "' + desc + '"');
  lines.push('    author      = "' + author + '"');
  lines.push('    severity    = "' + severity + '"');
  lines.push('    date        = "' + date + '"');
  lines.push('  strings:');
  for (var i = 0; i < strs.length; i++) {
    var s = strs[i];
    var val = s.type === 'hex' ? '{ ' + s.value + ' }' : s.type === 'regex' ? '/' + s.value + '/' : '"' + s.value + '"';
    var mod = s.mod ? ' ' + s.mod : '';
    lines.push('    $' + s.name + ' = ' + val + mod);
  }
  lines.push('  condition:');
  lines.push('    ' + condition);
  lines.push('}');
  return lines.join('\n');
}

function updatePreview() {
  var el = document.getElementById('preview-content');
  if (el) el.textContent = buildRule();
  var name = document.getElementById('ruleName').value || 'untitled';
  var fn = document.getElementById('preview-filename');
  if (fn) fn.textContent = name + '.yar';
}

function validateRule() {
  var name = document.getElementById('ruleName').value.trim();
  var desc = document.getElementById('metaDesc').value.trim();
  var author = document.getElementById('metaAuthor').value.trim();
  var condition = document.getElementById('condition').value.trim();
  var strs = getStrings();
  var errors = [];
  if (!name) errors.push('Rule name is required');
  else if (!/^[a-zA-Z_][a-zA-Z0-9_]*$/.test(name)) errors.push('Rule name must start with a letter or underscore, no spaces');
  if (!desc) errors.push('Description is required');
  if (!author) errors.push('Author is required');
  if (strs.length === 0) errors.push('At least one string is required');
  for (var i = 0; i < strs.length; i++) {
    if (!strs[i].value.trim()) errors.push('String #' + (i+1) + ' value is empty');
    if (!strs[i].name.trim()) errors.push('String #' + (i+1) + ' identifier is empty');
    if (strs[i].type === 'hex' && !/^[0-9A-Fa-f\s]+$/.test(strs[i].value)) errors.push('String #' + (i+1) + ' hex value has invalid characters');
  }
  if (!condition) errors.push('Condition is required');
  var div = document.getElementById('validation-result');
  if (errors.length === 0) {
    div.innerHTML = '<div class="validation valid">[+] Rule is valid! Switch to Preview tab to see and download your rule.</div>';
  } else {
    var html = '<div class="validation invalid">';
    for (var i = 0; i < errors.length; i++) html += '<div class="error-line">[!] ' + errors[i] + '</div>';
    html += '</div>';
    div.innerHTML = html;
  }
}

function copyRule() {
  var text = document.getElementById('preview-content').textContent;
  navigator.clipboard.writeText(text);
  var btn = event.target;
  btn.textContent = 'COPIED!';
  setTimeout(function() { btn.textContent = 'COPY'; }, 2000);
}

function downloadRule() {
  var text = document.getElementById('preview-content').textContent;
  var name = document.getElementById('ruleName').value || 'rule';
  var blob = new Blob([text], { type: 'text/plain' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url; a.download = name + '.yar'; a.click();
}

function exampleRule(ex) {
  var lines = ['rule ' + ex.name + ' {', '  meta:', '    description = "' + ex.desc + '"', '    author      = "' + ex.author + '"', '    severity    = "' + ex.severity + '"', '  strings:'];
  for (var i = 0; i < ex.strings.length; i++) {
    var s = ex.strings[i];
    var val = s.type === 'hex' ? '{ ' + s.value + ' }' : '"' + s.value + '"';
    var mod = s.mod ? ' ' + s.mod : '';
    lines.push('    $' + s.name + ' = ' + val + mod);
  }
  lines.push('  condition:', '    ' + ex.condition, '}');
  return lines.join('\n');
}

function loadExample(idx) {
  var ex = EXAMPLES[idx];
  document.getElementById('ruleName').value = ex.name;
  document.getElementById('metaDesc').value = ex.desc;
  document.getElementById('metaAuthor').value = ex.author;
  document.getElementById('metaSeverity').value = ex.severity;
  document.getElementById('condition').value = ex.condition;
  document.getElementById('strings-container').innerHTML = '';
  stringCount = 0; strings = [];
  for (var i = 0; i < ex.strings.length; i++) addString(ex.strings[i]);
  document.getElementById('validation-result').innerHTML = '';
  document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.screen').forEach(function(s) { s.classList.remove('active'); });
  document.querySelector('.tab').classList.add('active');
  document.getElementById('tab-builder').classList.add('active');
  updatePreview();
}

function renderExamples() {
  var c = document.getElementById('examples-container');
  var sevClass = { LOW:'sev-low', MEDIUM:'sev-medium', HIGH:'sev-high', CRITICAL:'sev-critical' };
  var html = '';
  for (var i = 0; i < EXAMPLES.length; i++) {
    var ex = EXAMPLES[i];
    html += '<div class="example-card"><div class="example-header"><span class="example-name">' + ex.name.replace(/_/g,' ') + '</span><span class="severity ' + sevClass[ex.severity] + '">' + ex.severity + '</span></div><div class="example-desc">' + ex.desc + '</div><pre class="example-pre">' + exampleRule(ex) + '</pre><button class="btn btn-green btn-small" onclick="loadExample(' + i + ')">LOAD INTO BUILDER</button></div>';
  }
  c.innerHTML = html;
}

window.onload = function() {
  document.getElementById('metaDate').value = new Date().toISOString().split('T')[0];
  addString();
  renderExamples();
  updatePreview();
};
</script>
</body>
</html>
